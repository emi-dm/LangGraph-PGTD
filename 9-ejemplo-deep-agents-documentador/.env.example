# =============================================================================
# Variables de entorno para el Sistema Multiagente Documentador
# =============================================================================

# OpenRouter API Key - Acceso unificado a múltiples modelos LLM
# Obtén tu API key en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Modelo a usar a través de OpenRouter (opcional, default: anthropic/claude-sonnet-4)
# Opciones populares:
#   - anthropic/claude-sonnet-4
#   - anthropic/claude-opus-4
#   - openai/gpt-4o
#   - openai/gpt-4o-mini
#   - meta-llama/llama-3.1-70b-instruct
#   - google/gemini-2.0-flash
OPENROUTER_MODEL=

# Tavily API Key - Búsqueda web optimizada para LLMs
# Obtén tu API key en: https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# Langfuse - Observabilidad y trazas de agentes
# Obtén tus keys en: https://cloud.langfuse.com/
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
